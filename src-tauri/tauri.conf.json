{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ruxer",
  "version": "0.3.4",
  "identifier": "app.fluxer.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../web run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../web run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/basement-interactive/Ruxer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3MUE0MUZCMjY5OEY4MzgKUldRNCtKZ20rMEVhbC9PMzBZOXk3UWpkVjJKclNReHJVdlRMSkFQRVM2emtSQURmRFdNRk9mUWgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}