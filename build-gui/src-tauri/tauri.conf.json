{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fluxer Build GUI",
  "version": "0.1.0",
  "identifier": "app.fluxer.buildgui",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fluxer Build GUI",
        "width": 980,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
