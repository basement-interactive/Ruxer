# Copy this file to `.env` and fill in your values.
# Never commit the filled-in `.env`.

# Required: your Fluxer token.
#   - Bot token:    starts with the bot's token string (sent as `Authorization: Bot <token>`)
#   - Session token: a user session token from login (sent as `Authorization: <token>`)
#   - Bearer token: an OAuth2 access token (sent as `Authorization: Bearer <token>`)
FLUXER_TOKEN=

# Required: how FLUXER_TOKEN should be sent. One of: session | bot | bearer
# - session -> use a user session token obtained from logging in (default for a client)
# - bot     -> use a bot token from the Fluxer developer portal
# - bearer  -> use an OAuth2 access token
FLUXER_TOKEN_TYPE=session

# Optional: a channel ID to send a test message and reaction to.
FLUXER_TARGET_CHANNEL=

# Optional: override the REST API base URL (e.g. for a self-hosted instance).
# Leave blank to use the default https://api.fluxer.app/v1
FLUXER_API_BASE=

# Optional: override the gateway WebSocket URL.
# Leave blank to use the value reported by GET /gateway/bot (or wss://gateway.fluxer.app).
FLUXER_GATEWAY_URL=
